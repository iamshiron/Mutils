# Docker Environment Overrides
# Copy to .env in the docker directory or set in parent .env

# PostgreSQL
POSTGRES_USER=mutils
POSTGRES_PASSWORD=mutils_dev_password
POSTGRES_DB=mutils
POSTGRES_PORT=5432

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_ASSETS=mutils-assets
MINIO_BUCKET_USER_DATA=mutils-user-data

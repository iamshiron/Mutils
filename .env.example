# Discord OAuth
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:5173/auth/callback

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_characters_long
JWT_EXPIRY_HOURS=24
JWT_ISSUER=mutils
JWT_AUDIENCE=mutils-users

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mutils
POSTGRES_USER=mutils
POSTGRES_PASSWORD=mutils_dev_password

# Connection String (alternative)
ConnectionStrings__Default=Host=localhost;Port=5432;Database=mutils;Username=mutils;Password=mutils_dev_password

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_ASSETS=mutils-assets
MINIO_BUCKET_USER_DATA=mutils-user-data

# Backend
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000

# Frontend (exposed to browser)
VITE_API_URL=http://localhost:5000/api
VITE_DISCORD_CLIENT_ID=your_discord_client_id

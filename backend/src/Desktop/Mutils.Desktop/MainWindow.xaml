<Window x:Class="Mutils.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Mutils.Desktop"
        mc:Ignorable="d"
        Title="Mutils Desktop" Height="700" Width="1100"
        Background="#121212" Foreground="White"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <!-- Nav Button Style -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#BBB"/>
            <Setter Property="Padding" Value="25,15"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="0,20,20,0" Margin="0,2,20,2">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A2A2A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Header1" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="1.25" ScaleY="1.25"/>
        </Grid.LayoutTransform>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#181818">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="0,30,0,30">
                    <TextBlock Text="MUTILS" FontSize="28" FontWeight="ExtraBold" Foreground="#7289DA" Margin="30,0,0,0"/>
                    <TextBlock Text="OCR Tracker" FontSize="12" Foreground="#555" Margin="32,-5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button x:Name="DashboardNav" Content="Dashboard" Style="{StaticResource NavButton}" Background="#252525" Foreground="White" Click="OnDashboardClick"/>
                    <Button x:Name="CollectionNav" Content="Collection" Style="{StaticResource NavButton}" Click="OnCollectionClick"/>
                    <Button x:Name="HistoryNav" Content="History" Style="{StaticResource NavButton}" Click="OnHistoryClick"/>
                    <Button x:Name="SettingsNav" Content="Settings" Style="{StaticResource NavButton}" Click="OnSettingsClick"/>
                </StackPanel>

                <Border Grid.Row="2" Padding="20" Background="#141414">
                    <StackPanel>
                        <TextBlock x:Name="UserStatusText" Text="Not Logged In" FontSize="10" Foreground="#666" Margin="0,0,0,10"/>
                        <Button x:Name="LoginButton" Content="Login with Discord" Click="OnLoginClick" Background="#7289DA" Foreground="White" Padding="10,5" FontSize="11" FontWeight="Bold" BorderThickness="0" Visibility="Visible">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button x:Name="LogoutButton" Content="Logout" Click="OnLogoutClick" Background="#333" Foreground="White" Padding="10,5" FontSize="11" BorderThickness="0" Visibility="Collapsed">
                             <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Separator Background="#222" Margin="0,15"/>
                        <TextBlock Text="API Status" FontSize="10" Foreground="#666"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#FF5252" Margin="0,0,8,0"/>
                            <TextBlock x:Name="StatusText" Text="Disconnected" FontSize="12" Foreground="#AAA"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Border Grid.Row="0" BorderBrush="#252525" BorderThickness="0,0,0,1" Padding="30,0">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Live Tracker" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="Tracking: #mudae-rolls (Discord)" Foreground="#666" FontSize="12"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="Start Capture" Background="#7289DA" BorderThickness="0" Foreground="White" FontWeight="Bold" Margin="0,0,10,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Padding" Value="20,8"/>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Set Capture Area" Background="#333" BorderThickness="0" Foreground="White">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Padding" Value="15,8"/>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Scrollable Content Area -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <Grid>
                    <!-- Dashboard Content -->
                    <StackPanel x:Name="DashboardView" Margin="20" Visibility="Visible">
                        <!-- Top Summary Stats -->
                        <UniformGrid Columns="3">
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Total Rolls Captured" Foreground="#AAA" FontSize="12"/>
                                    <TextBlock Text="128" FontSize="32" FontWeight="Bold" Margin="0,5,0,0"/>
                                    <TextBlock Text="+12 this session" Foreground="#4CAF50" FontSize="10" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Kakera Buttons Seen" Foreground="#AAA" FontSize="12"/>
                                    <TextBlock Text="42" FontSize="32" FontWeight="Bold" Margin="0,5,0,0" Foreground="#9C27B0"/>
                                    <TextBlock Text="3x Purple, 12x Blue" Foreground="#AAA" FontSize="10" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Claims Logged" Foreground="#AAA" FontSize="12"/>
                                    <TextBlock Text="14" FontSize="32" FontWeight="Bold" Margin="0,5,0,0" Foreground="#2196F3"/>
                                    <TextBlock Text="Tracking your Mudae progress" Foreground="#AAA" FontSize="10" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Recent Activity Section -->
                        <TextBlock Text="Live Captures" Style="{StaticResource Header1}" Margin="10,20,10,10"/>
                        <Border Style="{StaticResource Card}" Padding="0">
                            <StackPanel>
                                <!-- List Header -->
                                <Border Background="#252525" Padding="20,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Time" Foreground="#666" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text="Character" Foreground="#666" FontSize="12"/>
                                        <TextBlock Grid.Column="2" Text="Series" Foreground="#666" FontSize="12"/>
                                        <TextBlock Grid.Column="3" Text="Kakera" Foreground="#666" FontSize="12"/>
                                        <TextBlock Grid.Column="4" Text="Keys" Foreground="#666" FontSize="12"/>
                                        <TextBlock Grid.Column="5" Text="Claimed?" Foreground="#666" FontSize="12"/>
                                    </Grid>
                                </Border>

                                <!-- Items -->
                                <ItemsControl>
                                    <!-- Item 1 -->
                                    <Border BorderBrush="#252525" BorderThickness="0,0,0,1" Padding="20,15">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="14:22:01" VerticalAlignment="Center" Foreground="#AAA"/>
                                            <TextBlock Grid.Column="1" Text="Rem" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="Re:Zero" Foreground="#AAA" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="-" Foreground="#444" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="12" Foreground="#AAA" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="5" Text="No" Foreground="#444" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <!-- Item 2 -->
                                    <Border BorderBrush="#252525" BorderThickness="0,0,0,1" Padding="20,15">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="14:21:45" VerticalAlignment="Center" Foreground="#AAA"/>
                                            <TextBlock Grid.Column="1" Text="Megumin" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="Konosuba" Foreground="#AAA" VerticalAlignment="Center"/>
                                            <Border Grid.Column="3" Background="#4A148C" Padding="6,2" CornerRadius="4" HorizontalAlignment="Left">
                                                <TextBlock Text="Purple" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                            <TextBlock Grid.Column="4" Text="5" Foreground="#AAA" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="5" Text="Yes" Foreground="#4CAF50" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <!-- Item 3 -->
                                    <Border Padding="20,15">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="14:20:12" VerticalAlignment="Center" Foreground="#AAA"/>
                                            <TextBlock Grid.Column="1" Text="Chisa Kotegawa" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="Grand Blue" Foreground="#AAA" VerticalAlignment="Center"/>
                                            <Border Grid.Column="3" Background="#0D47A1" Padding="6,2" CornerRadius="4" HorizontalAlignment="Left">
                                                <TextBlock Text="Blue" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                            <TextBlock Grid.Column="4" Text="1" Foreground="#AAA" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="5" Text="Yes" Foreground="#4CAF50" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </ItemsControl>
                                
                                <Button Content="View Full History" Background="Transparent" Foreground="#7289DA" BorderThickness="0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Collection Content -->
                    <StackPanel x:Name="CollectionView" Margin="20" Visibility="Collapsed">
                        <Grid Margin="0,0,0,20">
                            <TextBlock Text="My Collection" Style="{StaticResource Header1}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBox x:Name="CollectionSearchTextBox" TextChanged="OnCollectionSearchChanged" Width="200" Padding="8,4" Margin="0,0,10,0" Background="#1E1E1E" Foreground="White" BorderBrush="#333" BorderThickness="1"/>
                                <Button Content="Refresh" Click="OnRefreshCollectionClick" Padding="15,5" Background="#333" Foreground="White" BorderThickness="0"/>
                            </StackPanel>
                        </Grid>

                        <Border x:Name="LoginRequiredOverlay" Style="{StaticResource Card}" Visibility="Visible">
                            <StackPanel HorizontalAlignment="Center" Margin="50">
                                <TextBlock Text="Login Required" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                                <TextBlock Text="Please login with Discord to view your collection." Foreground="#AAA" Margin="0,0,0,20" HorizontalAlignment="Center"/>
                                <Button Content="Login with Discord" Click="OnLoginClick" Padding="20,10" Background="#7289DA" Foreground="White" FontWeight="Bold" BorderThickness="0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <ListView x:Name="CollectionListView" 
                                  Background="Transparent" 
                                  BorderThickness="0" 
                                  Foreground="White" 
                                  Visibility="Collapsed"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#252525" BorderThickness="0,0,0,1" Padding="15,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/> <!-- Image -->
                                                <ColumnDefinition Width="2*"/> <!-- Name/Series -->
                                                <ColumnDefinition Width="80"/> <!-- Rank -->
                                                <ColumnDefinition Width="100"/> <!-- Kakera -->
                                                <ColumnDefinition Width="80"/> <!-- Keys -->
                                                <ColumnDefinition Width="100"/> <!-- Date -->
                                            </Grid.ColumnDefinitions>

                                            <!-- Image -->
                                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="4" ClipToBounds="True" Background="#252525">
                                                <Image Source="{Binding Character.ImageUrl}" Stretch="UniformToFill"/>
                                            </Border>

                                            <!-- Name & Series -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0">
                                                <TextBlock Text="{Binding Character.Name}" FontWeight="Bold" FontSize="14"/>
                                                <TextBlock Text="Mudae Collection" Foreground="#666" FontSize="11"/>
                                            </StackPanel>

                                            <!-- Rank -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Text="RANK" FontSize="9" Foreground="#555" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding Character.Rank, TargetNullValue='?'}" Foreground="#AAA"/>
                                            </StackPanel>

                                            <!-- Kakera -->
                                            <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                                <TextBlock Text="KAKERA" FontSize="9" Foreground="#555" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding Character.Kakera, StringFormat={}{0:N0} ka}" Foreground="#9C27B0" FontWeight="SemiBold"/>
                                            </StackPanel>

                                            <!-- Keys -->
                                            <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                                <TextBlock Text="KEYS" FontSize="9" Foreground="#555" FontWeight="Bold"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Character.KeyCount, TargetNullValue='0'}" Foreground="#FFD700"/>
                                                    <TextBlock Text=" ★" Foreground="#444" FontSize="10" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Date -->
                                            <StackPanel Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <TextBlock Text="ACQUIRED" FontSize="9" Foreground="#555" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding AcquiredAt, StringFormat=MMM dd\, yyyy}" Foreground="#666" FontSize="11" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                                    <ContentPresenter />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1A1A1A"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#222"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </StackPanel>

                    <!-- History Content -->
                    <StackPanel x:Name="HistoryView" Margin="20" Visibility="Collapsed">
                        <Grid Margin="0,0,0,20">
                            <TextBlock Text="Capture &amp; Claim History" Style="{StaticResource Header1}"/>
                            <Button Content="+ Log Kakera Claim" Click="OnShowAddKakeraClick" Padding="15,5" Background="#7289DA" Foreground="White" FontWeight="Bold" HorizontalAlignment="Right" BorderThickness="0">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </Grid>

                        <ListView x:Name="HistoryListView" Background="Transparent" BorderThickness="0" Foreground="White">
                             <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#252525" BorderThickness="0,0,0,1" Padding="15,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/> <!-- Time -->
                                                <ColumnDefinition Width="*"/> <!-- Event -->
                                                <ColumnDefinition Width="100"/> <!-- Details -->
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{Binding ClaimedAt, StringFormat=t}" Foreground="#666" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                                <TextBlock Text="{Binding CharacterName}" FontWeight="Bold"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="Manual Kakera Log" FontSize="11" Foreground="#444"/>
                                                    <TextBlock Text=" • " FontSize="11" Foreground="#333"/>
                                                    <TextBlock Text="Claimed" FontSize="11" Foreground="#4CAF50" Visibility="{Binding IsClaimed, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                    <TextBlock Text="Missed" FontSize="11" Foreground="#FF5252">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsClaimed}" Value="False">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                            <Border Grid.Column="2" Background="#2A2A2A" Padding="8,4" CornerRadius="4" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,35,0">
                                                <TextBlock Text="{Binding Type}" FontSize="10" FontWeight="Bold" Foreground="#9C27B0"/>
                                            </Border>

                                            <Button Grid.Column="2" Content="✕" Click="OnDeleteKakeraClaimClick" Tag="{Binding Id}" Background="Transparent" Foreground="#444" BorderThickness="0" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="5">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Foreground" Value="Red"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>

                    <!-- Settings Content -->
                    <StackPanel x:Name="SettingsView" Margin="40" Visibility="Collapsed">
                        <TextBlock Text="Settings" Style="{StaticResource Header1}" Margin="0,0,0,30"/>
                        
                        <Border Style="{StaticResource Card}" Width="500" HorizontalAlignment="Left" Margin="0">
                            <StackPanel>
                                <TextBlock Text="API Server Configuration" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,20"/>
                                
                                <TextBlock Text="Server Base URL" Foreground="#AAA" Margin="0,0,0,8"/>
                                <TextBox x:Name="ApiUrlTextBox" 
                                         Background="#252525" 
                                         Foreground="White" 
                                         BorderThickness="1" 
                                         BorderBrush="#444" 
                                         Padding="10,8" 
                                         Margin="0,0,0,20"
                                         Text="http://localhost:5000"/>
                                
                                <TextBlock Text="Status" Foreground="#AAA" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                                    <Ellipse x:Name="SettingsStatusDot" Width="8" Height="8" Fill="#FF5252" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="SettingsStatusText" Text="Disconnected from API" FontSize="12" Foreground="#AAA"/>
                                </StackPanel>
                                
                                <Button Content="Save Settings" 
                                        Click="OnSaveSettingsClick"
                                        Background="#7289DA" 
                                        Foreground="White" 
                                        BorderThickness="0" 
                                        Padding="20,10" 
                                        FontWeight="Bold"
                                        HorizontalAlignment="Left">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- Modals/Overlays -->
        <Grid x:Name="ModalOverlay" Visibility="Collapsed" Background="#CC000000" Grid.ColumnSpan="2">
            <Border Style="{StaticResource Card}" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center" BorderBrush="#333" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Log Kakera Claim" Style="{StaticResource Header1}" Margin="0,0,0,20"/>

                    <TextBlock Text="Character Name" Foreground="#AAA" Margin="0,0,0,5"/>
                    <TextBox x:Name="ClaimCharacterTextBox" Background="#252525" Foreground="White" Padding="8,4" Margin="0,0,0,15" BorderBrush="#444"/>

                    <TextBlock Text="Kakera Type" Foreground="#AAA" Margin="0,0,0,5"/>
                    <ComboBox x:Name="KakeraTypeComboBox" Background="#252525" Foreground="White" Padding="8,4" Margin="0,0,0,15" BorderBrush="#444" BorderThickness="1">
                        <ComboBox.Resources>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Background" Value="#252525"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#333"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#7289DA"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Resources>
                        <ComboBoxItem Content="Purple"/>
                        <ComboBoxItem Content="Blue"/>
                        <ComboBoxItem Content="Green"/>
                        <ComboBoxItem Content="Yellow"/>
                        <ComboBoxItem Content="Orange"/>
                        <ComboBoxItem Content="Red"/>
                        <ComboBoxItem Content="Rainbow"/>
                        <ComboBoxItem Content="Light"/>
                        <ComboBoxItem Content="Chaos"/>
                        <ComboBoxItem Content="Dark"/>
                    </ComboBox>

                    <TextBlock Text="Value" Foreground="#AAA" Margin="0,0,0,5"/>
                    <TextBox x:Name="ClaimValueTextBox" Text="120" Background="#252525" Foreground="White" Padding="8,4" Margin="0,0,0,15" BorderBrush="#444"/>

                    <CheckBox x:Name="IsClaimedCheckBox" Content="Claimed?" IsChecked="True" Foreground="White" Margin="0,0,0,25">
                        <CheckBox.Style>
                            <Style TargetType="CheckBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="CheckBox">
                                            <StackPanel Orientation="Horizontal">
                                                <Border x:Name="border" Width="18" Height="18" Background="#252525" BorderBrush="#444" BorderThickness="1" CornerRadius="3">
                                                    <TextBlock x:Name="check" Text="✓" Foreground="#7289DA" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="12"/>
                                                </Border>
                                                <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#7289DA"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </CheckBox.Style>
                    </CheckBox>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Click="OnCancelAddKakeraClick" Padding="15,8" Background="Transparent" Foreground="#AAA" BorderThickness="0" Margin="0,0,10,0"/>
                        <Button Content="Save Claim" Click="OnSaveKakeraClaimClick" Padding="20,8" Background="#7289DA" Foreground="White" FontWeight="Bold" BorderThickness="0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
